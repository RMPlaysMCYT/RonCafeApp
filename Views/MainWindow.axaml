<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:RonCafeApp.ViewModels"
        xmlns:models="using:RonCafeApp.Models"
        xmlns:conv="clr-namespace:RonCafeApp.Converters"
        WindowState="Maximized"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="750"
        x:Class="RonCafeApp.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Ron Cafe Launcher"
        Background="{Binding LauncherBackground}">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <conv:StringToImageConverter x:Key="ImgConv"/>
    </Window.Resources>

    <Grid ColumnDefinitions="200, *">

        <!-- ── Sidebar ── -->
        <Border Grid.Column="0" Background="{Binding SidebarBackground}" Padding="10">
            <Grid RowDefinitions="Auto, Auto, *, Auto">
                <Image Grid.Row="0" Stretch="Uniform" Width="160" Height="200" Source="avares://RonCafeApp/Assets/placeholder.png"/>
                <TextBlock Grid.Row="1" Text="{Binding CurrentTime}" Foreground="White" FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Padding="0 0 0  20"/>
                <ListBox Grid.Row="2"
                         Padding="0,20,0,0"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         Background="Transparent"
                         Foreground="White"/>
                <Button Grid.Row="3"
                        Content="⚙ Settings"
                        Command="{Binding PromptSettingsPassword}"
                        Foreground="AntiqueWhite"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1">

            <ScrollViewer Padding="20"
                          IsVisible="{Binding CurrentPage,
                              Converter={x:Static ObjectConverters.IsNull}}">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedCategory}"
                               FontSize="40"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"
                               Foreground="White"/>
                    <TextBlock IsVisible="{Binding IsAppListEmpty}"
                               Text="No apps in this category yet. Open Settings to add some!"
                               VerticalAlignment="Center"
                               Foreground="#A6ADC8"
                               HorizontalAlignment="Center"
                               Margin="0,250,0,0"
                               FontSize="14"/>

                    <ItemsControl ItemsSource="{Binding DisplayedApps}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:AppItem">
                            <Panel Margin="5" Width="150" Height="250" VerticalAlignment="Top">
                                
                                <Border Background="#313244" CornerRadius="0" Padding="5">
                                    <Panel>
                                        
                                        <!-- ── VIEW 1: Square Icon + Name + Button ── -->
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Spacing="8"
                                                    IsVisible="{Binding !$parent[Window].((vm:MainWindowViewModel)DataContext).UseCoverArtView}">
                                            
                                            <Image Width="64" Height="64" 
                                                   Source="{Binding IconPlaceholder, Converter={StaticResource ImgConv}}"
                                                   HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="130"
                                                       FontSize="12"/>
                                            <Button Content="▶ Launch"
                                                    Background="#A6E3A1"
                                                    Foreground="#11111B"
                                                    FontWeight="Bold"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Center"
                                                    Padding="6,4"
                                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LaunchApp}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>

                                        <!-- ── VIEW 2: Clickable Cover Art ── -->
                                        <!-- We wrap the Image in a Button, make the Button transparent, and assign the Launch command directly to it! -->
                                        <Button Background="Transparent" 
                                                Padding="0" 
                                                BorderThickness="0"
                                                HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LaunchApp}"
                                                CommandParameter="{Binding}"
                                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).UseCoverArtView}"
                                                ToolTip.Tip="{Binding Name}">
                                            
                                            <!-- The image itself -->
                                            <Image Width="120" Height="220" Stretch="UniformToFill"
                                                   Source="{Binding CoverArtPlaceholder, Converter={StaticResource ImgConv}}"/>
                                        </Button>
                                        
                                    </Panel>
                                </Border>
                                
                                <!-- ── Lock Overlay (Stays the same!) ── -->
                                <Border Background="#B3000000" CornerRadius="10" 
                                        IsVisible="{Binding CategoryLocked}" 
                                        IsHitTestVisible="False">
                                    <TextBlock Text="🔒 LOCKED" 
                                               Foreground="#F38BA8" 
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Panel>
                        </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            <!-- Settings overlay -->
            <ContentControl Content="{Binding CurrentPage}"
                            Background="{Binding LauncherBackground}"
                            IsVisible="{Binding CurrentPage,
                                Converter={x:Static ObjectConverters.IsNotNull}}"/>
            <TextBlock Text="Version 1.0.2"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,10,10"
                       Foreground="#A6ADC8"
                       />
        </Grid>
    </Grid>
</Window>