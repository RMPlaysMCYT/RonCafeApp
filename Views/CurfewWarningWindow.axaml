<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RonCafeApp.Views.CurfewWarningWindow"
        Title="Curfew Warning" Width="400" Height="150"
        Background="Transparent" TransparencyLevelHint="AcrylicBlur"
        SystemDecorations="None" Topmost="True" WindowStartupLocation="CenterScreen" CanResize="False">
    <Border Background="#CCFF5555" CornerRadius="15" Padding="20">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="⚠️ CURFEW WARNING" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="Games will be closed in 5 minutes." FontSize="16" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            <Button Content="Dismiss" Click="CloseClick" HorizontalAlignment="Center" Margin="0,15,0,0"/>
        </StackPanel>
    </Border>
</Window>