<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RonCafeApp.Views.PasswordScreen">
    <Panel>
        <Button Content="Settings" Click="OpenSettings_Click" VerticalAlignment="Top" HorizontalAlignment="Left"/>

        <Popup Name="PasswordPopup" 
               IsLightDismissEnabled="True" 
               PlacementMode="AnchorAndGravity" 
               PlacementTarget="{Binding ElementName=MainContainer}">
            <views:PasswordScreen />
        </Popup>

        <Grid Name="MainContainer">
        </Grid>
    </Panel>
</UserControl>
