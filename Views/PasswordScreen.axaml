<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RonCafeApp.Views.PasswordScreen">
    
    <!-- A semi-transparent background to dark out whatever is behind it -->
    <Grid Background="#B3000000">
        
        <!-- The actual password card -->
        <Border Padding="25" Background="#181825" CornerRadius="12" 
                BorderBrush="#313244" BorderThickness="2"
                HorizontalAlignment="Center" VerticalAlignment="Center"
            
            <StackPanel Spacing="15" Width="250">
                <TextBlock Text="🔒 Admin Override" 
                           FontSize="20" FontWeight="Bold" 
                           Foreground="#F38BA8" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                
                <TextBox Name="PasswordInput" 
                         PasswordChar="•" 
                         Watermark="Enter Admin Password"
                         Background="#313244" Foreground="White"/>
                
                <Button Content="Unlock" 
                        Background="#A6E3A1" Foreground="#11111B" 
                        FontWeight="Bold" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                
                <Button Content="Cancel" 
                        Background="Transparent" Foreground="#A6ADC8" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>