<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RonCafeApp.ViewModels"
             x:Class="RonCafeApp.Views.PasswordScreen"
             x:DataType="vm:MainWindowViewModel">
    
    <Grid Background="#B3000000">
        <!-- FIXED: Added the closing > to the Border tag -->
        <Border Padding="25" Background="#181825" CornerRadius="12" 
                BorderBrush="#313244" BorderThickness="2"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <StackPanel Spacing="15" Width="250">
                <TextBlock Text="🔒 Admin Required" 
                           FontSize="20" FontWeight="Bold" 
                           Foreground="#F38BA8" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                
                <!-- Bound the text to a property in ViewModel -->
                <TextBox Text="{Binding AdminPasswordInput}" 
                         PasswordChar="•" 
                         Watermark="Enter Admin Password"
                         Background="#313244" Foreground="White"/>
                
                <!-- Bound to the submit command -->
                <Button Content="Unlock" 
                        Command="{Binding SubmitPasswordCommand}"
                        Background="#A6E3A1" Foreground="#11111B" 
                        FontWeight="Bold" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                
                <!-- Bound to a cancel command -->
                <Button Content="Cancel" 
                        Command="{Binding CancelPasswordCommand}"
                        Background="Transparent" Foreground="#A6ADC8" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>